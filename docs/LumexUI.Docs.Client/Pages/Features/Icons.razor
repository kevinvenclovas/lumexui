@page "/docs/features/icons"
@layout DocsContentLayout

@using System.Reflection

<div class="w-full max-w-6xl mx-auto px-4 py-8">

    <h1 class="text-4xl font-bold mb-2">Icons</h1>
    <p class="text-foreground/60 mb-8">Browse and search through all available Lucide icons</p>

    <div class="grid grid-cols gap-3">
        <LumexAlert>
            <ChildContent>
                <span>
                    A wrapper for <LumexLink External="@true" href="https://lucide.dev/">Lucide Icons</LumexLink> with optional settings for size, color, fill, stroke, and custom classes. Browse available icons in the Lucide library to see what you can use.
                </span>
            </ChildContent>
        </LumexAlert>

        <!-- Icons Grid -->
        @if (allIcons.Count > 0)
        {
            <div class="grid grid-cols-6 sm:grid-cols-10 gap-3">

                @foreach (var icon in allIcons)
                {
                    <LumexButton IconOnly="@true" Variant="@Variant.Flat" Color="@ThemeColor.Default" OnClick="@(() => OpenIconModal(icon))">
                        <DynamicIcon Type="@icon.type" Size="24" />
                    </LumexButton>
                }
            </div>
        }
        else
        {
            <div class="text-center py-12">
                <p class="text-foreground/60">No icons found</p>
            </div>
        }
    </div>
</div>



@code {
    protected record Icon(string Name, Type type);

    private List<Icon> allIcons = new();
    private bool isModalOpen = false;
    private Icon? selectedIcon = null;

    protected override void OnInitialized()
    {
        // Get all icon component names from the assembly
        var assembly = typeof(IconBase).Assembly;
        var iconTypes = assembly.GetTypes()
            .Where(t => !t.IsAbstract &&
                        t.BaseType?.Name == "IconBase")
            .OrderBy(n => n.Name)
            .ToList();

        // Use only first 10 as test
        allIcons = iconTypes.Select(x => new Icon(FormatIconName(x.Name), x)).Take(10).ToList();
    }



    private string FormatIconName(string iconName)
    {
        // Remove "Icon" suffix and add spaces before capitals
        var name = iconName.Replace("Icon", "");
        return System.Text.RegularExpressions.Regex.Replace(name, "(?<!^)(?=[A-Z])", " ");
    }

    protected async Task OpenIconModal(Icon icon)
    {
        selectedIcon = icon;
        isModalOpen = true;
    }

}

